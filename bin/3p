#!/usr/bin/env bash
set -euo pipefail

# 3p: 3ペイン構成で tmux セッションを生成する
# 左ペイン: yazi  中ペイン: yazi  右ペイン: claude

SESSION_NAME="3p-${1:-$(basename "$PWD")}"
PROJECT_ROOT="${2:-$PWD}"

attach_or_switch() {
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$SESSION_NAME"
  else
    tmux attach-session -t "$SESSION_NAME"
  fi
}

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  attach_or_switch
  exit 0
fi

tmux new-session -d -s "$SESSION_NAME" -c "$PROJECT_ROOT"
tmux send-keys -t "$SESSION_NAME:0.0" "yazi" C-m
tmux split-window -h -t "$SESSION_NAME" -c "$PROJECT_ROOT"
tmux send-keys -t "$SESSION_NAME:0.1" "yazi" C-m
tmux split-window -h -t "$SESSION_NAME" -c "$PROJECT_ROOT"
tmux send-keys -t "$SESSION_NAME:0.2" "claude" C-m
tmux select-layout -t "$SESSION_NAME" even-horizontal
attach_or_switch
